#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_help() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main --help
  echo ""
  echo "=== 10-domain CLI (post-convergence) ==="
  echo ""
  echo "核心入口:"
  echo "  ./trade run <target>      统一触发 (DAG/daily/agenda/job/belief/recommend/picks)"
  echo "  ./trade status            综合健康体检 (原 trade doctor; cron 友好: 0=ok 1=warn 2=fail)"
  echo "  ./trade status data       数据层状态 (原 data status)"
  echo "  ./trade status jobs       任务执行状态 (原 data jobs status)"
  echo "  ./trade status freshness  多资产新鲜度 (原 ops freshness)"
  echo "  ./trade web [args]        启动 Web Console (FastAPI + React)"
  echo ""
  echo "只读视图 (show):"
  echo "  ./trade show dag          pipeline DAG"
  echo "  ./trade show events       最近事件日志"
  echo "  ./trade show runs         job 执行历史"
  echo "  ./trade show calendar     交易日历 / 未来事件"
  echo "  ./trade show agenda       agenda 队列"
  echo "  ./trade show backups      最近备份"
  echo ""
  echo "研究 (research):"
  echo "  ./trade research model <cmd>    模型训练/推理/对比/上线"
  echo "  ./trade research factor <cmd>   因子评估"
  echo "  ./trade research evaluate <cmd> 质量门禁评估"
  echo "  ./trade kg ...                  Learned KG 流程"
  echo ""
  echo "配置 (config):"
  echo "  ./trade config init/show/get/set/doctor"
  echo "  ./trade config source ...       数据源启停/注册"
  echo "  ./trade config dag ...          DAG 节点开关"
  echo "  ./trade config watch ...        自选股管理"
  echo ""
  echo "数据 (data):"
  echo "  ./trade data sync              统一同步 (crypto/fx/commodity)"
  echo "  ./trade data kline             A 股 K线"
  echo "  ./trade data fund-flow         资金流向"
  echo "  ./trade data fundamental       财务数据"
  echo "  ./trade data northbound        北向资金"
  echo "  ./trade data index             指数数据"
  echo "  ./trade data macro             宏观数据"
  echo "  ./trade data warehouse         数据仓库 / RSS"
  echo "  ./trade data realtime          实时行情"
  echo "  ./trade data btc               BTC assurance"
  echo ""
  echo "运维/事件:"
  echo "  ./trade event trigger/run/sync/add/rebuild/backfill"
  echo "  ./trade backup create/push/restore/list"
  echo "  ./trade start                  启动 EventBus daemon"
  echo ""
  echo "常用 workflow 快捷:"
  echo "  ./trade open → trade run open"
  echo "  ./trade close → trade run close"
  echo "  ./trade morning|intraday|evening → trade run <target>"
  echo ""
  echo "向后兼容 (弃用命令仍可用，会打印提示):"
  echo "  ./trade doctor → trade status"
  echo "  ./trade inspect → trade show"
  echo "  ./trade model|factor|evaluate → trade research <group>"
  echo "  ./trade daily → trade run / trade status"
  echo "  ./trade ops → trade status / trade run"
  echo "  ./trade account watch-* → trade config watch"
  echo ""
  echo "开发命令:"
  echo "  ./trade setup-python       uv sync"
  echo "  ./trade configure [preset] CMake configure (default: linux-clang)"
  echo "  ./trade build [preset]     CMake build"
  echo "  ./trade test [preset]      ctest"
  echo "  ./trade cli <args>         运行 C++ trade_cli 二进制"
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing command: $1"
    exit 1
  fi
}

default_preset() {
  echo "${1:-linux-clang}"
}

compiler_major() {
  local cxx="${CXX:-g++}"
  if ! command -v "$cxx" >/dev/null 2>&1; then
    echo "0"
    return
  fi
  "$cxx" -dumpversion 2>/dev/null | awk -F. '{print $1}'
}

cmd_setup_python() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv sync
}

cmd_configure() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd cmake
  cd "$ROOT_DIR"
  cmake --preset "$preset"
}

cmd_build() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd cmake
  cd "$ROOT_DIR"
  cmake --build --preset "$preset" -j"$(nproc)"
}

cmd_cli() {
  if [ $# -lt 1 ]; then
    echo "Usage: ./trade cli <command> [args...]"
    exit 1
  fi
  local candidates=(
    "$ROOT_DIR/build/linux-clang/bin/trade_cli"
    "$ROOT_DIR/build/linux/bin/trade_cli"
    "$ROOT_DIR/build/default/bin/trade_cli"
  )
  local bin=""
  for c in "${candidates[@]}"; do
    if [ -x "$c" ]; then
      bin="$c"
      break
    fi
  done
  if [ -z "$bin" ]; then
    echo "trade_cli not found in build presets:"
    printf '  - %s\n' "${candidates[@]}"
    echo "Run: ./trade configure linux-clang && ./trade build linux-clang"
    exit 1
  fi

  local build_root
  build_root="$(cd "$(dirname "$bin")/.." && pwd)"
  local lib_candidates=(
    "$build_root/vendor/arrow/cpp/release"
    "$build_root/engine/vendor/arrow/cpp/release"
    "$ROOT_DIR/engine/vendor/lightgbm"
  )
  local extra_ld=""
  local d
  for d in "${lib_candidates[@]}"; do
    if [ -d "$d" ]; then
      if [ -n "$extra_ld" ]; then
        extra_ld="${extra_ld}:$d"
      else
        extra_ld="$d"
      fi
    fi
  done
  if [ -n "${LD_LIBRARY_PATH:-}" ]; then
    LD_LIBRARY_PATH="${extra_ld}:${LD_LIBRARY_PATH}" "$bin" "$@"
  else
    LD_LIBRARY_PATH="${extra_ld}" "$bin" "$@"
  fi
}

cmd_py() {
  if [ $# -lt 1 ]; then
    echo "Usage: ./trade py <domain> [args...]"
    exit 1
  fi
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main "$@"
}

cmd_domain() {
  local domain="$1"; shift || true
  require_cmd uv
  cd "$ROOT_DIR"
  if [ $# -eq 0 ]; then
    uv run python -m trade_py.cli.main "$domain" --help
  else
    uv run python -m trade_py.cli.main "$domain" "$@"
  fi
}

cmd_domain_allow_empty() {
  local domain="$1"; shift || true
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main "$domain" "$@"
}

cmd_test() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd ctest
  cd "$ROOT_DIR"
  ctest --preset "$preset"
}

main() {
  # Collect global flags (-v/--verbose/-q/--quiet) from anywhere in the args
  local global_flags=()
  local sub=""
  local sub_args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -v|--verbose) global_flags+=("$1"); shift ;;
      -q|--quiet) global_flags+=("$1"); shift ;;
      -h|--help|help)
        if [ -z "$sub" ]; then
          print_help
          exit 0
        else
          sub_args+=("$1"); shift
        fi
        ;;
      *)
        if [ -z "$sub" ]; then
          sub="$1"
        else
          sub_args+=("$1")
        fi
        shift
        ;;
    esac
  done
  if [ -z "$sub" ]; then
    sub="help"
  fi

  case "$sub" in
    # Workflow shortcuts → run
    morning|intraday|evening|agenda|open|close|sync) cmd_domain run "$sub" "${global_flags[@]}" "${sub_args[@]}" ;;
    # The 10 canonical domains
    run) cmd_domain run "${global_flags[@]}" "${sub_args[@]}" ;;
    status) cmd_domain_allow_empty status "${global_flags[@]}" "${sub_args[@]}" ;;
    show) cmd_domain show "${global_flags[@]}" "${sub_args[@]}" ;;
    research) cmd_domain research "${global_flags[@]}" "${sub_args[@]}" ;;
    data) cmd_domain data "${global_flags[@]}" "${sub_args[@]}" ;;
    kg) cmd_domain kg "${global_flags[@]}" "${sub_args[@]}" ;;
    config) cmd_domain config "${global_flags[@]}" "${sub_args[@]}" ;;
    event) cmd_domain event "${global_flags[@]}" "${sub_args[@]}" ;;
    backup) cmd_domain backup "${global_flags[@]}" "${sub_args[@]}" ;;
    start) cmd_domain_allow_empty start "${global_flags[@]}" "${sub_args[@]}" ;;
    web) cmd_domain_allow_empty web "${global_flags[@]}" "${sub_args[@]}" ;;
    dev) cmd_domain dev "${global_flags[@]}" "${sub_args[@]}" ;;
    # Legacy/deprecated domains (still work, dispatch to Python which prints deprecation warning)
    doctor) cmd_domain_allow_empty "$sub" "${global_flags[@]}" "${sub_args[@]}" ;;
    inspect|daily|ops|account|model|factor|evaluate)
      cmd_domain "$sub" "${global_flags[@]}" "${sub_args[@]}" ;;
    # Build/setup commands
    setup-python) cmd_setup_python "${sub_args[@]}" ;;
    configure) cmd_configure "${sub_args[@]}" ;;
    build) cmd_build "${sub_args[@]}" ;;
    cli) cmd_cli "${sub_args[@]}" ;;
    py) cmd_py "${sub_args[@]}" ;;
    test) cmd_test "${sub_args[@]}" ;;
    brief|report|schedule|ui) echo "$sub 已移除。请使用 ./trade status、./trade show 或 ./trade web。" ;;
    help|-h|--help) print_help ;;
    *)
      echo "错误：未知命令 '$sub'"
      echo "运行 './trade help' 查看用法"
      exit 1
      ;;
  esac
}

main "$@"
