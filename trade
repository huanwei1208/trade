#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_help() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main --help
  echo ""
  echo "正式入口:"
  echo "  ./trade run <args>         统一触发入口（事件 / agenda / job）"
  echo "  ./trade status [args]      系统总览（质量门禁 / agenda / 最近执行）"
  echo "  ./trade inspect <args>     统一查看入口（dag / calendar / agenda / kg 等）"
  echo "  ./trade web [args]         启动 TradeDB Web Console"
  echo "  ./trade backup <args>      备份与恢复（本地快照 / Google Drive）"
  echo ""
  echo "高级域（调试 / 细分任务）:"
  echo "  ./trade data <args>        数据采集"
  echo "  ./trade model <args>       模型与信号分析"
  echo "  ./trade factor <args>      因子仓与因子评估"
  echo "  ./trade report <args>      报告生成"
  echo "  ./trade account <args>     账户与自选股管理"
  echo "  ./trade event <args>       事件管理 / DAG / job 触发"
  echo "  ./trade evaluate <args>    评估层与质量门禁"
  echo "  ./trade kg <args>          Learned KG 候选边学习 / 审核 / 上线"
  echo "  ./trade start <args>       启动 EventBus daemon"
  echo "  ./trade serve <args>       启动 Web UI / 在线服务"
  echo ""
  echo "快捷命令 (bash 层):"
  echo "  ./trade morning            →  trade run morning"
  echo "  ./trade intraday           →  trade run intraday"
  echo "  ./trade evening            →  trade run evening"
  echo "  ./trade agenda [args]      →  trade run agenda [args]"
  echo "  ./trade open               →  trade run open"
  echo "  ./trade close              →  trade run close"
  echo "  ./trade sync               →  trade run sync"
  echo "  ./trade today              →  trade status"
  echo "  ./trade check              →  trade status"
  echo "  ./trade overview           →  trade status"
  echo "  ./trade console            →  trade serve"
  echo "  ./trade web                →  trade serve"
  echo "  ./trade dashboard          →  trade serve"
  echo "  ./trade dag [args]         →  trade inspect dag [args]"
  echo "  ./trade pipeline [args]    →  trade inspect dag [args]"
  echo "  ./trade calendar [args]    →  trade inspect calendar [args]"
  echo "  ./trade events [args]      →  trade inspect events [args]"
  echo "  ./trade hive [args]        →  trade inspect hive [args]"
  echo "  ./trade workflows [args]   →  trade inspect workflows [args]"
  echo "  ./trade factors [args]     →  trade inspect factors [args]"
  echo "  ./trade models [args]      →  trade inspect models [args]"
  echo "  ./trade backups [args]     →  trade inspect backups [args]"
  echo "  ./trade sentiment [args]   →  trade data sentiment [args]"
  echo "  ./trade brief [args]       →  trade report brief [args]"
  echo "  ./trade schedule [args]    →  trade report schedule [args]"
  echo ""
  echo "开发命令:"
  echo "  ./trade doctor             检查 cmake/gcc/uv 环境"
  echo "  ./trade setup-python       uv sync"
  echo "  ./trade configure [preset] CMake configure (default: linux-clang)"
  echo "  ./trade build [preset]     CMake build"
  echo "  ./trade test [preset]      ctest"
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing command: $1"
    exit 1
  fi
}

default_preset() {
  echo "${1:-linux-clang}"
}

compiler_major() {
  local cxx="${CXX:-g++}"
  if ! command -v "$cxx" >/dev/null 2>&1; then
    echo "0"
    return
  fi
  "$cxx" -dumpversion 2>/dev/null | awk -F. '{print $1}'
}

cmd_doctor() {
  echo "Project root: $ROOT_DIR"
  echo "Tools:"
  for x in cmake ninja g++ gcc uv; do
    if command -v "$x" >/dev/null 2>&1; then
      echo "  - $x: $(command -v "$x")"
    else
      echo "  - $x: MISSING"
    fi
  done
  local gmaj
  gmaj="$(compiler_major)"
  if [ "$gmaj" -lt 10 ]; then
    echo "Compiler check: FAIL (GCC/G++ >= 10 required, current major=$gmaj)"
    echo "Hint: install gcc-13 g++-13 and set CC/CXX accordingly."
  else
    echo "Compiler check: OK (major=$gmaj)"
  fi
}

cmd_setup_python() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv sync
}

cmd_configure() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd cmake
  cd "$ROOT_DIR"
  cmake --preset "$preset"
}

cmd_build() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd cmake
  cd "$ROOT_DIR"
  cmake --build --preset "$preset" -j"$(nproc)"
}

cmd_cli() {
  if [ $# -lt 1 ]; then
    echo "Usage: ./trade cli <command> [args...]"
    exit 1
  fi
  local candidates=(
    "$ROOT_DIR/build/linux-clang/bin/trade_cli"
    "$ROOT_DIR/build/linux/bin/trade_cli"
    "$ROOT_DIR/build/default/bin/trade_cli"
  )
  local bin=""
  for c in "${candidates[@]}"; do
    if [ -x "$c" ]; then
      bin="$c"
      break
    fi
  done
  if [ -z "$bin" ]; then
    echo "trade_cli not found in build presets:"
    printf '  - %s\n' "${candidates[@]}"
    echo "Run: ./trade configure linux-clang && ./trade build linux-clang"
    exit 1
  fi

  local build_root
  build_root="$(cd "$(dirname "$bin")/.." && pwd)"
  local lib_candidates=(
    "$build_root/vendor/arrow/cpp/release"
    "$build_root/engine/vendor/arrow/cpp/release"
    "$ROOT_DIR/engine/vendor/lightgbm"
  )
  local extra_ld=""
  local d
  for d in "${lib_candidates[@]}"; do
    if [ -d "$d" ]; then
      if [ -n "$extra_ld" ]; then
        extra_ld="${extra_ld}:$d"
      else
        extra_ld="$d"
      fi
    fi
  done
  if [ -n "${LD_LIBRARY_PATH:-}" ]; then
    LD_LIBRARY_PATH="${extra_ld}:${LD_LIBRARY_PATH}" "$bin" "$@"
  else
    LD_LIBRARY_PATH="${extra_ld}" "$bin" "$@"
  fi
}

cmd_ui() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv run streamlit run trade_py/ui/ui.py "$@"
}

cmd_py() {
  if [ $# -lt 1 ]; then
    echo "Usage: ./trade py <domain> [args...]"
    exit 1
  fi
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main "$@"
}

cmd_trade_py_domain() {
  local domain="$1"; shift || true
  require_cmd uv
  cd "$ROOT_DIR"
  if [ $# -eq 0 ]; then
    uv run python -m trade_py.cli.main "$domain" --help
  else
    uv run python -m trade_py.cli.main "$domain" "$@"
  fi
}

cmd_trade_py_domain_allow_empty() {
  local domain="$1"; shift || true
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main "$domain" "$@"
}

cmd_test() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd ctest
  cd "$ROOT_DIR"
  ctest --preset "$preset"
}

main() {
  local sub="${1:-help}"
  shift || true
  case "$sub" in
    morning|intraday|evening|agenda|open|close|sync) cmd_trade_py_domain run "$sub" "$@" ;;
    today|check|overview) cmd_trade_py_domain_allow_empty status "$@" ;;
    dag|pipeline) cmd_trade_py_domain inspect dag "$@" ;;
    calendar) cmd_trade_py_domain inspect calendar "$@" ;;
    events) cmd_trade_py_domain inspect events "$@" ;;
    hive) cmd_trade_py_domain inspect hive "$@" ;;
    workflows|workflow) cmd_trade_py_domain inspect workflows "$@" ;;
    factors) cmd_trade_py_domain inspect factors "$@" ;;
    models) cmd_trade_py_domain inspect models "$@" ;;
    backups) cmd_trade_py_domain inspect backups "$@" ;;
    run) cmd_trade_py_domain run "$@" ;;
    status) cmd_trade_py_domain_allow_empty status "$@" ;;
    inspect) cmd_trade_py_domain inspect "$@" ;;
    backup) cmd_trade_py_domain backup "$@" ;;
    doctor) cmd_doctor "$@" ;;
    setup-python) cmd_setup_python "$@" ;;
    configure) cmd_configure "$@" ;;
    build) cmd_build "$@" ;;
    cli) cmd_cli "$@" ;;
    data) cmd_trade_py_domain data "$@" ;;
    model) cmd_trade_py_domain model "$@" ;;
    factor) cmd_trade_py_domain factor "$@" ;;
    report) cmd_trade_py_domain report "$@" ;;
    account) cmd_trade_py_domain account "$@" ;;
    event) cmd_trade_py_domain event "$@" ;;
    evaluate) cmd_trade_py_domain evaluate "$@" ;;
    kg) cmd_trade_py_domain kg "$@" ;;
    start) cmd_trade_py_domain_allow_empty start "$@" ;;
    serve|web|console|dashboard) cmd_trade_py_domain_allow_empty serve "$@" ;;
    sentiment) cmd_trade_py_domain data sentiment "$@" ;;
    brief)     cmd_trade_py_domain report brief "$@" ;;
    schedule)  cmd_trade_py_domain report schedule "$@" ;;
    py) cmd_py "$@" ;;
    ui) cmd_ui "$@" ;;
    test) cmd_test "$@" ;;
    help|-h|--help) print_help ;;
    *)
      echo "错误：未知命令 '$sub'"
      echo "可用顶层命令: run | status | inspect | web | dashboard | console | backup | today | check | overview | dag | pipeline | calendar | events | hive | workflows | factors | models | backups | data | model | factor | report | account | event | evaluate | kg | start | serve | sentiment | brief | schedule | ui | cli | py | doctor | setup-python | configure | build | test | help"
      echo "运行 './trade help' 查看详细用法"
      exit 1
      ;;
  esac
}

main "$@"
