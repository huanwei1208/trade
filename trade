#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_help() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main --help
  echo ""
  echo "核心入口:"
  echo "  ./trade run <args>         统一触发入口（事件 / agenda / job）"
  echo "  ./trade status [args]      系统总览（质量门禁 / agenda / 最近执行）"
  echo "  ./trade doctor [args]      一键健康检查（数据/任务/加密货币/事件/DB）"
  echo "  ./trade inspect <args>     数据/任务/DAG/事件浏览器"
  echo "  ./trade web [args]         启动 Web Console (FastAPI + React)"
  echo ""
  echo "常用 workflow:"
  echo "  ./trade sync               →  trade run sync"
  echo "  ./trade open               →  trade run open"
  echo "  ./trade close              →  trade run close"
  echo "  ./trade morning            →  trade run morning"
  echo "  ./trade intraday           →  trade run intraday"
  echo "  ./trade evening            →  trade run evening"
  echo ""
  echo "数据域:"
  echo "  ./trade data sync          统一元数据驱动同步 (crypto/fx/commodity)"
  echo "  ./trade data fetch kline   A 股 K线/资金流/财务/指数/宏观/新闻"
  echo "  ./trade data jobs status   任务运行状态与 watermark"
  echo "  ./trade data status        数据层完整性/时效性/覆盖率"
  echo "  ./trade data view <asset>  查看已落盘数据"
  echo ""
  echo "配置域:"
  echo "  ./trade config init        创建 config/trade.yaml"
  echo "  ./trade config show        显示所有配置 (DB + YAML + ENV)"
  echo "  ./trade config set/get     读写设置 (token/key/路径)"
  echo "  ./trade config source      数据源启停/注册 (asset_registry)"
  echo "  ./trade config dag         DAG 节点启用/禁用"
  echo "  ./trade config watch       自选股管理"
  echo "  ./trade config path        显示当前路径"
  echo "  ./trade config doctor      配置健康检查"
  echo ""
  echo "研究/评估:"
  echo "  ./trade model ...          模型训练/推理/对比/上线"
  echo "  ./trade factor ...         因子仓评估 (IC/分层)"
  echo "  ./trade evaluate ...       源/事件/模型/质量门禁评估"
  echo "  ./trade kg ...             Learned KG 候选边学习/审核/上线"
  echo ""
  echo "运维域:"
  echo "  ./trade event ...          事件触发/DAG/任务运行/重建"
  echo "  ./trade account suggest    候选股推荐"
  echo "  ./trade backup ...         备份与恢复（本地 / Google Drive）"
  echo "  ./trade start              启动 EventBus daemon"
  echo ""
  echo "开发命令:"
  echo "  ./trade setup-python       uv sync"
  echo "  ./trade configure [preset] CMake configure (default: linux-clang)"
  echo "  ./trade build [preset]     CMake build"
  echo "  ./trade test [preset]      ctest"
  echo "  ./trade cli <args>         运行 C++ trade_cli 二进制"
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing command: $1"
    exit 1
  fi
}

default_preset() {
  echo "${1:-linux-clang}"
}

compiler_major() {
  local cxx="${CXX:-g++}"
  if ! command -v "$cxx" >/dev/null 2>&1; then
    echo "0"
    return
  fi
  "$cxx" -dumpversion 2>/dev/null | awk -F. '{print $1}'
}

cmd_doctor() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main doctor "$@"
}

cmd_setup_python() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv sync
}

cmd_configure() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd cmake
  cd "$ROOT_DIR"
  cmake --preset "$preset"
}

cmd_build() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd cmake
  cd "$ROOT_DIR"
  cmake --build --preset "$preset" -j"$(nproc)"
}

cmd_cli() {
  if [ $# -lt 1 ]; then
    echo "Usage: ./trade cli <command> [args...]"
    exit 1
  fi
  local candidates=(
    "$ROOT_DIR/build/linux-clang/bin/trade_cli"
    "$ROOT_DIR/build/linux/bin/trade_cli"
    "$ROOT_DIR/build/default/bin/trade_cli"
  )
  local bin=""
  for c in "${candidates[@]}"; do
    if [ -x "$c" ]; then
      bin="$c"
      break
    fi
  done
  if [ -z "$bin" ]; then
    echo "trade_cli not found in build presets:"
    printf '  - %s\n' "${candidates[@]}"
    echo "Run: ./trade configure linux-clang && ./trade build linux-clang"
    exit 1
  fi

  local build_root
  build_root="$(cd "$(dirname "$bin")/.." && pwd)"
  local lib_candidates=(
    "$build_root/vendor/arrow/cpp/release"
    "$build_root/engine/vendor/arrow/cpp/release"
    "$ROOT_DIR/engine/vendor/lightgbm"
  )
  local extra_ld=""
  local d
  for d in "${lib_candidates[@]}"; do
    if [ -d "$d" ]; then
      if [ -n "$extra_ld" ]; then
        extra_ld="${extra_ld}:$d"
      else
        extra_ld="$d"
      fi
    fi
  done
  if [ -n "${LD_LIBRARY_PATH:-}" ]; then
    LD_LIBRARY_PATH="${extra_ld}:${LD_LIBRARY_PATH}" "$bin" "$@"
  else
    LD_LIBRARY_PATH="${extra_ld}" "$bin" "$@"
  fi
}

cmd_py() {
  if [ $# -lt 1 ]; then
    echo "Usage: ./trade py <domain> [args...]"
    exit 1
  fi
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main "$@"
}

cmd_domain() {
  local domain="$1"; shift || true
  require_cmd uv
  cd "$ROOT_DIR"
  if [ $# -eq 0 ]; then
    uv run python -m trade_py.cli.main "$domain" --help
  else
    uv run python -m trade_py.cli.main "$domain" "$@"
  fi
}

cmd_domain_allow_empty() {
  local domain="$1"; shift || true
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main "$domain" "$@"
}

cmd_test() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd ctest
  cd "$ROOT_DIR"
  ctest --preset "$preset"
}

main() {
  # Collect global flags (-v/--verbose/-q/--quiet) from anywhere in the args
  local global_flags=()
  local sub=""
  local sub_args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -v|--verbose) global_flags+=("$1"); shift ;;
      -q|--quiet) global_flags+=("$1"); shift ;;
      -h|--help|help)
        if [ -z "$sub" ]; then
          print_help
          exit 0
        else
          sub_args+=("$1"); shift
        fi
        ;;
      *)
        if [ -z "$sub" ]; then
          sub="$1"
        else
          sub_args+=("$1")
        fi
        shift
        ;;
    esac
  done
  if [ -z "$sub" ]; then
    sub="help"
  fi

  case "$sub" in
    morning|intraday|evening|agenda|open|close|sync) cmd_domain run "$sub" "${global_flags[@]}" "${sub_args[@]}" ;;
    run) cmd_domain run "${global_flags[@]}" "${sub_args[@]}" ;;
    status) cmd_domain_allow_empty status "${global_flags[@]}" "${sub_args[@]}" ;;
    doctor) cmd_doctor "${global_flags[@]}" "${sub_args[@]}" ;;
    inspect) cmd_domain inspect "${global_flags[@]}" "${sub_args[@]}" ;;
    data) cmd_domain data "${global_flags[@]}" "${sub_args[@]}" ;;
    config) cmd_domain config "${global_flags[@]}" "${sub_args[@]}" ;;
    model) cmd_domain model "${global_flags[@]}" "${sub_args[@]}" ;;
    factor) cmd_domain factor "${global_flags[@]}" "${sub_args[@]}" ;;
    account) cmd_domain account "${global_flags[@]}" "${sub_args[@]}" ;;
    event) cmd_domain event "${global_flags[@]}" "${sub_args[@]}" ;;
    evaluate) cmd_domain evaluate "${global_flags[@]}" "${sub_args[@]}" ;;
    kg) cmd_domain kg "${global_flags[@]}" "${sub_args[@]}" ;;
    backup) cmd_domain backup "${global_flags[@]}" "${sub_args[@]}" ;;
    start) cmd_domain_allow_empty start "${global_flags[@]}" "${sub_args[@]}" ;;
    web) cmd_domain_allow_empty web "${global_flags[@]}" "${sub_args[@]}" ;;
    ops) cmd_domain ops "${global_flags[@]}" "${sub_args[@]}" ;;
    daily) cmd_domain daily "${global_flags[@]}" "${sub_args[@]}" ;;
    dev) cmd_domain dev "${global_flags[@]}" "${sub_args[@]}" ;;
    setup-python) cmd_setup_python "${sub_args[@]}" ;;
    configure) cmd_configure "${sub_args[@]}" ;;
    build) cmd_build "${sub_args[@]}" ;;
    cli) cmd_cli "${sub_args[@]}" ;;
    py) cmd_py "${sub_args[@]}" ;;
    test) cmd_test "${sub_args[@]}" ;;
    brief|report|schedule|ui) echo "$sub 已移除。请使用 ./trade status、./trade inspect 或 ./trade web。" ;;
    help|-h|--help) print_help ;;
    *)
      echo "错误：未知命令 '$sub'"
      echo "运行 './trade help' 查看用法"
      exit 1
      ;;
  esac
}

main "$@"
