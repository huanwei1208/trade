#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_help() {
  cat <<'EOF'
Unified entrypoint for the trade project

Usage:
  ./trade doctor
  ./trade setup-python
  ./trade configure [preset]
  ./trade build [preset]
  ./trade cli <command> [args...]
  ./trade data <args...>
  ./trade model <args...>
  ./trade report <args...>
  ./trade account <args...>
  ./trade py <domain> [args...]
  ./trade ui [streamlit args...]
  ./trade test [preset]

Default preset:
  linux-clang
EOF
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing command: $1"
    exit 1
  fi
}

default_preset() {
  echo "${1:-linux-clang}"
}

compiler_major() {
  local cxx="${CXX:-g++}"
  if ! command -v "$cxx" >/dev/null 2>&1; then
    echo "0"
    return
  fi
  "$cxx" -dumpversion 2>/dev/null | awk -F. '{print $1}'
}

cmd_doctor() {
  echo "Project root: $ROOT_DIR"
  echo "Tools:"
  for x in cmake ninja g++ gcc uv; do
    if command -v "$x" >/dev/null 2>&1; then
      echo "  - $x: $(command -v "$x")"
    else
      echo "  - $x: MISSING"
    fi
  done
  local gmaj
  gmaj="$(compiler_major)"
  if [ "$gmaj" -lt 10 ]; then
    echo "Compiler check: FAIL (GCC/G++ >= 10 required, current major=$gmaj)"
    echo "Hint: install gcc-13 g++-13 and set CC/CXX accordingly."
  else
    echo "Compiler check: OK (major=$gmaj)"
  fi
}

cmd_setup_python() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv sync
}

cmd_configure() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd cmake
  cd "$ROOT_DIR"
  cmake --preset "$preset"
}

cmd_build() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd cmake
  cd "$ROOT_DIR"
  cmake --build --preset "$preset" -j"$(nproc)"
}

cmd_cli() {
  if [ $# -lt 1 ]; then
    echo "Usage: ./trade cli <command> [args...]"
    exit 1
  fi
  local candidates=(
    "$ROOT_DIR/build/linux-clang/bin/trade_cli"
    "$ROOT_DIR/build/linux/bin/trade_cli"
    "$ROOT_DIR/build/default/bin/trade_cli"
  )
  local bin=""
  for c in "${candidates[@]}"; do
    if [ -x "$c" ]; then
      bin="$c"
      break
    fi
  done
  if [ -z "$bin" ]; then
    echo "trade_cli not found in build presets:"
    printf '  - %s\n' "${candidates[@]}"
    echo "Run: ./trade configure linux-clang && ./trade build linux-clang"
    exit 1
  fi

  local build_root
  build_root="$(cd "$(dirname "$bin")/.." && pwd)"
  local lib_candidates=(
    "$build_root/vendor/arrow/cpp/release"
    "$build_root/engine/vendor/arrow/cpp/release"
    "$ROOT_DIR/engine/vendor/lightgbm"
  )
  local extra_ld=""
  local d
  for d in "${lib_candidates[@]}"; do
    if [ -d "$d" ]; then
      if [ -n "$extra_ld" ]; then
        extra_ld="${extra_ld}:$d"
      else
        extra_ld="$d"
      fi
    fi
  done
  if [ -n "${LD_LIBRARY_PATH:-}" ]; then
    LD_LIBRARY_PATH="${extra_ld}:${LD_LIBRARY_PATH}" "$bin" "$@"
  else
    LD_LIBRARY_PATH="${extra_ld}" "$bin" "$@"
  fi
}

cmd_ui() {
  require_cmd uv
  cd "$ROOT_DIR"
  uv run streamlit run trade_py/ui/ui.py "$@"
}

cmd_py() {
  if [ $# -lt 1 ]; then
    echo "Usage: ./trade py <domain> [args...]"
    exit 1
  fi
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main "$@"
}

cmd_trade_py_domain() {
  local domain="$1"
  shift || true
  require_cmd uv
  cd "$ROOT_DIR"
  uv run python -m trade_py.cli.main "$domain" "$@"
}

cmd_test() {
  local preset
  preset="$(default_preset "${1:-}")"
  require_cmd ctest
  cd "$ROOT_DIR"
  ctest --preset "$preset"
}

main() {
  local sub="${1:-help}"
  shift || true
  case "$sub" in
    doctor) cmd_doctor "$@" ;;
    setup-python) cmd_setup_python "$@" ;;
    configure) cmd_configure "$@" ;;
    build) cmd_build "$@" ;;
    cli) cmd_cli "$@" ;;
    data) cmd_trade_py_domain data "$@" ;;
    model) cmd_trade_py_domain model "$@" ;;
    report) cmd_trade_py_domain report "$@" ;;
    account) cmd_trade_py_domain account "$@" ;;
    py) cmd_py "$@" ;;
    ui) cmd_ui "$@" ;;
    test) cmd_test "$@" ;;
    help|-h|--help) print_help ;;
    *)
      echo "Unknown command: $sub"
      print_help
      exit 1
      ;;
  esac
}

main "$@"
