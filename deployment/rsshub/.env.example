RSSHUB_PORT=1200

# RSSHub container resources
RSSHUB_MEM_LIMIT=1024m
RSSHUB_CPUS=1.0
RSSHUB_SHM_SIZE=256m
RSSHUB_CACHE_EXPIRE=600

# Redis container resources
REDIS_MEM_LIMIT=512m
REDIS_CPUS=0.5
REDIS_MAX_MEMORY=256mb

# Docker log rotation
RSSHUB_LOG_MAX_SIZE=50m
RSSHUB_LOG_MAX_FILE=3

RSSHUB_ALLOW_ORIGIN=http://127.0.0.1:1200
